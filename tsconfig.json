{
    "compilerOptions": {
        "module": "node16",
        "esModuleInterop": true,
        "target": "es2016",
        "moduleResolution": "node16",
        "skipLibCheck": true,
        "sourceMap": true,
        "allowJs": true,
        "rootDir": "./",
        "outDir": "./dist",
        "declaration": true,
        "resolveJsonModule": true,
        "types": ["node"],
        "isolatedModules": true
    },
    "lib": ["es2015"],
    "include": ["./src/*.ts", "./tests/*.ts"]
}
